# Copy to .env and set per-learner values.  .env is git-ignored.
# deploy/00_env.sh loads this automatically; anything unset falls back to the
# defaults baked into 00_env.sh.

# Existing resource group under the learner account (do NOT create it)
RG=rg-lab10-agent

LOCATION=eastus
ACR=acrlab10vrl                 # -> acrlab10vrl.azurecr.io (globally unique, lowercase)
ACA_ENV=cae-lab10               # Container Apps environment
APP=bank-triage-agent           # the Container App name
IMAGE_REPO=bank-triage-agent    # repo inside ACR
APP_INSIGHTS=appi-lab10         # reuse an existing one if you have it

# Optional: image tag (CI sets this to the git sha; defaults to 'local')
# TAG=local
